{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["admin", "user"] },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "email", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "An AI news article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "readTime": { "type": "string" },
        "imageUrl": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "summary", "content", "category", "readTime", "imageUrl", "author", "date", "published", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "elitePrice": { "type": "number" },
        "currency": { "type": "string" }
      },
      "required": ["elitePrice", "currency"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles."
    },
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Published and draft articles."
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global settings like pricing. Typically document ID is 'global'."
    }
  }
}
